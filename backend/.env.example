# =============================================================================
# Shree Renukamba Communication - Backend Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values.
# cp .env.example .env
# =============================================================================

# --- Server ---
PORT=5000
NODE_ENV=development

# --- Database (PostgreSQL - Supabase) ---
# Get these values from your Supabase project dashboard at https://supabase.com
# Go to Project Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-ID].supabase.co:5432/postgres

# --- JWT Authentication ---
# Generate a random secret key (e.g., using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your_jwt_secret_here_change_this_in_production

# --- Email Service (Resend) ---
# Sign up at https://resend.com and get an API key from the API Keys section
RESEND_API_KEY=re_xxxxxxxxxxxx

# --- Email Fallback (Nodemailer / SMTP) ---
# Used when Resend fails. You can use Gmail App Password, SendGrid, or any SMTP provider.
# For Gmail: Enable 2FA, generate App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_or_smtp_password

# --- WhatsApp Business API ---
# Get these from Meta Developer Dashboard at https://developers.facebook.com
# 1. Create a WhatsApp Business App
# 2. Go to WhatsApp > Getting Started
# 3. Copy the Phone Number ID and Temporary Access Token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token
WHATSAPP_BUSINESS_PHONE=+919876543210

# --- OpenAI / AI Assistant ---
# Get API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxx

# --- Cloudinary (Image/File Storage) ---
# Sign up at https://cloudinary.com, get from Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Razorpay (Payment Gateway) ---
# Sign up at https://razorpay.com, get from Dashboard > API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
