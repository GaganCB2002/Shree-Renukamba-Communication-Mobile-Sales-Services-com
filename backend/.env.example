# =============================================================================
# Shree Renukamba Communication - Backend Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values.
#   cp .env.example .env
#
# For production deployment (Render), set these as Environment Variables
# in the Render Dashboard (not in a .env file).
# =============================================================================

# --- Server ---
PORT=5000
NODE_ENV=development              # 'development' for local, 'production' for Render

# --- Database ---
# Option A: SQLite (default for local dev) — no config needed, file stored at backend/database/app.db
# Option B: PostgreSQL / Supabase (for production)
# Get from Supabase: Project Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-ID].supabase.co:5432/postgres

# SQLite custom path (optional — defaults to backend/database/app.db)
# SQLITE_DB_PATH=./database/app.db

# --- JWT Authentication ---
# Generate a random secret key:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_change_this_in_production

# --- Supabase (for Auth / Storage / Realtime) ---
# Get from Supabase: Project Settings > API
# URL: Project Settings > API > Project URL
# Anon Key: Project Settings > API > anon/public key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Fallback (without VITE_ prefix, used if VITE_SUPABASE_* are not set):
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key

# --- Email Service (Resend) [https://resend.com] ---
# Sign up at https://resend.com, go to API Keys section to create a key
RESEND_API_KEY=re_xxxxxxxxxxxx

# --- Email Fallback (Nodemailer / SMTP) ---
# Used when Resend fails. For Gmail: Enable 2FA, then generate App Password
# at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_or_smtp_password

# --- WhatsApp Business API [https://developers.facebook.com] ---
# 1. Create a WhatsApp Business App in Meta Developer Dashboard
# 2. Go to WhatsApp > Getting Started
# 3. Copy the Phone Number ID and generate a Temporary Access Token
# 4. For webhook: use https://your-render-url.onrender.com/api/whatsapp/webhook
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token
WHATSAPP_BUSINESS_PHONE=+919876543210       # Your WhatsApp Business phone number

# --- OpenAI / AI Assistant [https://platform.openai.com] ---
# Get API key from https://platform.openai.com/api-keys
# Used for AI-powered responses in the assistant feature
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxx

# --- Cloudinary (Image/File Storage) [https://cloudinary.com] ---
# Sign up free, get credentials from Dashboard
# Used for uploading product images, repair photos, etc.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Razorpay (Payment Gateway) [https://razorpay.com] ---
# Sign up, go to Dashboard > API Keys to generate test/live keys
# Key ID format: rzp_test_xxxx (test) or rzp_live_xxxx (live)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
